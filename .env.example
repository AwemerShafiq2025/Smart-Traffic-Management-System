# ─────────────────────────────────────────────────────────────────────────────
# Smart Traffic Management System – Environment Variables Template
#
# HOW TO USE
#   1. Copy this file:   cp .env.example .env
#   2. Fill in the values below (never commit the real .env to Git).
#   3. The application reads these via python-dotenv or Docker --env-file.
# ─────────────────────────────────────────────────────────────────────────────


# ── Application ───────────────────────────────────────────────────────────────

# FastAPI environment: "development" | "staging" | "production"
APP_ENV=development

# Human-readable name shown in API docs / logs.
APP_NAME="Smart Traffic Management System"

# Semantic version of the running release.
APP_VERSION=1.0.0

# Set to "false" in production to hide the interactive /docs UI.
DEBUG=true


# ── FastAPI / Uvicorn ─────────────────────────────────────────────────────────

# Host and port the Uvicorn server binds to inside the container.
API_HOST=0.0.0.0
API_PORT=8000

# Number of Uvicorn worker processes.
# Rule of thumb: (2 × number_of_CPU_cores) + 1
UVICORN_WORKERS=2

# Comma-separated list of allowed CORS origins.
# Use "*" only during development; specify exact origins in production.
CORS_ORIGINS=http://localhost:3000,http://localhost:8000


# ── MySQL Database ────────────────────────────────────────────────────────────
#
# LOCAL (XAMPP) – use these when running the FastAPI server on your own machine:
#   DB_HOST=localhost
#   DB_PORT=3306
#
# DOCKER – the Compose service name "db" is the DNS hostname inside the
#   Docker network, so set DB_HOST=db when running via docker-compose.
#
# The full SQLAlchemy / mysqlclient connection URL is assembled from the
# individual variables below so you can override just one piece at a time.
# ─────────────────────────────────────────────────────────────────────────────

DB_HOST=localhost
DB_PORT=3306
DB_NAME=smart_traffic
DB_USER=traffic_user
DB_PASSWORD=change_me_before_using

# Assembled connection URL (used by SQLAlchemy / db_handler.py).
# Format: mysql+mysqlclient://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=mysql+mysqlclient://traffic_user:change_me_before_using@localhost:3306/smart_traffic

# MySQL connection-pool settings (tune for production load).
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800


# ── Security ──────────────────────────────────────────────────────────────────

# Random secret used to sign JWT tokens. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace_with_a_long_random_secret_key

# JWT token lifetime in minutes.
ACCESS_TOKEN_EXPIRE_MINUTES=60


# ── Traffic Controller Defaults ───────────────────────────────────────────────

# These mirror the defaults in TrafficController.__init__ and can be overridden
# at runtime without changing source code.
SIGNAL_MIN_GREEN_S=2
SIGNAL_MAX_GREEN_S=6
SIGNAL_YELLOW_S=2
SIGNAL_RED_S=10
SIGNAL_SECONDS_PER_CAR=1


# ── Logging ───────────────────────────────────────────────────────────────────

# Python logging level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Optional: write structured JSON logs to a file in production.
# Leave blank to log to stdout only (recommended for Docker / Kubernetes).
LOG_FILE=
